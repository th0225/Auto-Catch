@page "/"
@using System.Net.Http.Json

@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IndexedDbService IndexedDbService


<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8">
    @if (_isLoading)
    {
        <MudSkeleton SkeletonType="SkeletonType.Rectangle"
                     Height="200px"
                     Class="mb-4" />
        <MudSkeleton SkeletonType="SkeletonType.Rectangle"
                     Height="200px" />
    }
    else if (_posts == null || !_posts.Any())
    {
        <MudAlert Severity="Severity.Info">目前尚無抓取資料...</MudAlert>
    }
    else
    {
        <MudGrid>
            @foreach (var post in _posts)
            {
                <MudItem xs="12">
                    <MudCard Elevation="2"
                             Class="rounded-lg mb-4">
                        <MudCardHeader>
                            <CardHeaderAvatar>
                                <MudAvatar Color="Color.Primary"
                                           Variant="Variant.Filled">
                                    @post.Platform.Substring(0, 1).ToUpper()
                                </MudAvatar>
                            </CardHeaderAvatar>
                            <CardHeaderContent>
                                <MudText Typo="Typo.body1">
                                    <b>@post.Author</b>
                                </MudText>
                                <MudText Typo="Typo.caption">
                                    @post.CapturedAt.ToString("yyyy-MM-dd HH:mm") • @post.Platform
                                </MudText>
                            </CardHeaderContent>
                            <CardHeaderActions>
                                <MudIconButton
                                    Icon="@(IsCollected(post.Id) ? Icons.Material.Filled.Favorite : Icons.Material.Filled.FavoriteBorder)" 
                                    Color="@(IsCollected(post.Id) ? Color.Error : Color.Secondary)"
                                    OnClick="@(() => SaveToIndexedDb(post))" />
                                <MudIconButton
                                    Icon="@Icons.Material.Filled.Share" 
                                    Color="Color.Default" 
                                    Link="@post.Url" 
                                    Target="_blank" />
                            </CardHeaderActions>
                        </MudCardHeader>
                        
                        <MudCardContent>
                            @foreach (var tag in post.Tags)
                            {
                                <MudChip T="string" 
                                    Size="Size.Small" 
                                    Variant="Variant.Text" 
                                    Color="Color.Primary" 
                                    Class="mb-2">
                                    @tag
                                </MudChip>
                            }
                            <MudText Typo="Typo.body2">
                                @post.Content
                            </MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
</MudContainer>

@code {
    private List<SocialPost>? _posts = new();
    private HashSet<string> _collectedIds = [];
    private bool _isLoading = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _isLoading = true;
            // 讀取json資料
            _posts = await Http.GetFromJsonAsync<List<SocialPost>>(
                "data.json");

            // 讀取收藏的id
            var favorites =
                await IndexedDbService.GetFavoritesAsync();
            _collectedIds =
                favorites.Select(f => f.Id).ToHashSet();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"讀取失敗： {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task SaveToIndexedDb(SocialPost post)
    {
        bool isAdding = !_collectedIds.Contains(post.Id);
        if (isAdding)
        {
            _collectedIds.Add(post.Id);
        }
        else
        {
            _collectedIds.Remove(post.Id);
        }
        StateHasChanged();

        try
        {
            if (isAdding)
            {
                await IndexedDbService.UpsertRecordsAsync(post);
            }
            else
            {
                await IndexedDbService.RemoveRecordsAsync(post.Id);
            }

            Snackbar.Add(isAdding ? "已加入收藏清單！": "已取消收藏",
                isAdding ? Severity.Success : Severity.Info);
        }
        catch (Exception ex)
        {
            if (isAdding)
            {
                _collectedIds.Remove(post.Id);
            }
            else
            {
                _collectedIds.Add(post.Id);
            }

            Snackbar.Add($"資料庫同步失敗: {ex.Message}",
                Severity.Error);
            StateHasChanged();
        }
    }

    private bool IsCollected(string id)
    {
        return _collectedIds.Contains(id);
    }
}