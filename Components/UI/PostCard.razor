@inject IJSRuntime JS

<MudCard Elevation="2" Class="rounded-lg mb-4">
    <MudCardHeader>
        <CardHeaderAvatar>
            <MudAvatar Color="Color.Primary"
                        Variant="Variant.Filled">
                @Post.Platform.Substring(0, 1).ToUpper()
            </MudAvatar>
        </CardHeaderAvatar>
        <CardHeaderContent>
            <MudText Typo="Typo.body1">
                <b>@Post.Content</b>
            </MudText>
            <MudText Typo="Typo.caption" Style="color: gray;">
                @Post.Author • 
                @(Post.Date.Hour == 0 && Post.Date.Minute == 0 
                    ? Post.Date.ToString("yyyy-MM-dd") 
                    : Post.Date.ToString("yyyy-MM-dd HH:mm")) 
            </MudText>
        </CardHeaderContent>
        <CardHeaderActions>
            <MudIconButton
                Icon="@(IsFavorite ? Icons.Material.Filled.Favorite
                                   : Icons.Material.Filled.FavoriteBorder)" 
                Color="@(IsFavorite ? Color.Error : Color.Secondary)"
                OnClick="@(() => OnFavoriteToggle())" />
            <MudIconButton
                Icon="@Icons.Material.Filled.OpenInNew" 
                Color="Color.Default" 
                Href="@Post.Url" 
                Target="_blank" />
        </CardHeaderActions>
    </MudCardHeader>

    <MudCardContent>
        @foreach (var tag in Post.Tags)
        {
            <MudChip T="string" 
                Size="Size.Small" 
                Variant="Variant.Text" 
                Color="Color.Primary" 
                Class="mb-2">
                @tag
            </MudChip>
        }
    </MudCardContent>
</MudCard>

@code {
    [Parameter]
    public SocialPost Post { get; set; } = default!;
    
    [Parameter]
    public bool IsFavorite { get; set; } = false;

    [Parameter]
    public EventCallback<SocialPost> OnFavoriteChanged { get; set; }

    private async Task OnFavoriteToggle()
    {
        await OnFavoriteChanged.InvokeAsync(Post);
    }
}