@page "/"
@using System.Net.Http.Json
@using AutoCatch.Components
@using AutoCatch.Components.UI
@using AutoCatch.Service
@using AutoCatch.Models
@using MudBlazor
@using System.Text.Json

@inject ISnackbar Snackbar
@inject PostDbService PostDbService
@inject SettingDbService SettingDbService
@inject PttScraperService PttScraperService
@inject PostStateService PostStateService

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8">
    <div class="d-flex align-center justify-space-between mb-4">
        <div class="d-flex align-center">
            <MudText Typo="Typo.h5"
                     Style="font-weight: 800;"
                     Class="mud-text-primary mr-3">
                PTT 最新情報
            </MudText>
            @if (PostStateService.LastPttUpdateTime.HasValue)
            {
                <MudText
                    Typo="Typo.caption"
                    Style="color: var(--mud-palette-text-secondary);">
                    上次更新：@PostStateService.LastPttUpdateTime.Value.ToString("HH:mm:ss")
                </MudText>
            }
        </div>

        <MudIconButton Icon="@Icons.Material.Filled.Refresh" 
                       OnClick="ManualRefresh" 
                       Disabled="@PostStateService.IsLoading"
                       Color="Color.Primary"
                       Class="@(PostStateService.IsLoading ? "animate-spin" : "")" />
    </div>

    @if (PostStateService.IsLoading)
    {
        <MudSkeleton SkeletonType="SkeletonType.Rectangle"
                     Height="200px"
                     Class="mb-4" />
        <MudSkeleton SkeletonType="SkeletonType.Rectangle"
                     Height="200px" />
    }
    else if (PostStateService.PttPosts == null ||
            !PostStateService.PttPosts.Any())
    {
        <MudAlert Severity="Severity.Info">目前尚無抓取資料...</MudAlert>
    }
    else
    {
        <MudGrid Spacing="2">
            @foreach (var post in PostStateService.PttPosts)
            {
                <MudItem xs="12">
                    <PostCard Post="post"
                              IsFavorite="IsCollected(post.Id)"
                              OnFavoriteChanged="SaveToIndexedDb" />
                </MudItem>
            }
        </MudGrid>
    }
</MudContainer>

@code {
    private HashSet<string> _collectedIds = [];

    protected override async Task OnInitializedAsync()
    {
        if (PostStateService.PttPosts.Any())
        {
            return;
        }

        if (PostStateService.IsLoading)
        {
            return;
        }

        await RefreshPost();
    }

    private async Task ManualRefresh()
    {
        await RefreshPost();
    }

    private async Task RefreshPost()
    {
        PostStateService.IsLoading = true;

        try
        {
            var pttSettings =
                await SettingDbService.GetPttSettingsAsync();
            var threadsSettings = 
                await SettingDbService.GetThreadsSettingsAsync();

            if (pttSettings.Enabled)
            {
                PostStateService.PttPosts = 
                    await PttScraperService.CatchAllBoardsAsync(
                        pttSettings.BoardConfigs
                );
            }

            // 讀取收藏的id
            var favorites =
                await PostDbService.GetFavoritesAsync();
            _collectedIds =
                favorites.Select(f => f.Id).ToHashSet();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"讀取失敗： {ex.Message}");
        }
        finally
        {
            PostStateService.IsLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task SaveToIndexedDb(SocialPost post)
    {
        bool isAdding = !_collectedIds.Contains(post.Id);
        if (isAdding)
        {
            _collectedIds.Add(post.Id);
        }
        else
        {
            _collectedIds.Remove(post.Id);
        }
        StateHasChanged();

        try
        {
            if (isAdding)
            {
                await PostDbService.UpsertFavoriteAsync(post);
            }
            else
            {
                await PostDbService.RemoveFavoriteAsync(post.Id);
            }

            Snackbar.Add(isAdding ? "已加入收藏清單！": "已取消收藏",
                isAdding ? Severity.Success : Severity.Info);
        }
        catch (Exception ex)
        {
            if (isAdding)
            {
                _collectedIds.Remove(post.Id);
            }
            else
            {
                _collectedIds.Add(post.Id);
            }

            Snackbar.Add($"資料庫同步失敗: {ex.Message}",
                Severity.Error);
            StateHasChanged();
        }
    }

    private bool IsCollected(string id)
    {
        return _collectedIds.Contains(id);
    }
}