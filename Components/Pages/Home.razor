@page "/"
@using System.Net.Http.Json
@using AutoCatch.Components
@using AutoCatch.Components.UI
@using AutoCatch.Service
@using AutoCatch.Models
@using MudBlazor
@using System.Text.Json

@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IWebHostEnvironment Env
@inject PostDbService PostDbService
@inject PttScraperService PttScraperService

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8">
    @if (_isLoading)
    {
        <MudSkeleton SkeletonType="SkeletonType.Rectangle"
                     Height="200px"
                     Class="mb-4" />
        <MudSkeleton SkeletonType="SkeletonType.Rectangle"
                     Height="200px" />
    }
    else if (_posts == null || !_posts.Any())
    {
        <MudAlert Severity="Severity.Info">目前尚無抓取資料...</MudAlert>
    }
    else
    {
        <MudGrid Spacing="2">
            @foreach (var post in _posts)
            {
                <MudItem xs="12">
                    <PostCard Post="post"
                              IsFavorite="IsCollected(post.Id)"
                              OnFavoriteChanged="SaveToIndexedDb" />
                </MudItem>
            }
        </MudGrid>
    }
</MudContainer>

@code {
    private List<SocialPost>? _posts = new();
    private HashSet<string> _collectedIds = [];
    private bool _isLoading = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _isLoading = true;

            _posts = await PttScraperService.GetPttPosts(
                "Gossiping", 100);

            // 讀取收藏的id
            var favorites =
                await PostDbService.GetFavoritesAsync();
            _collectedIds =
                favorites.Select(f => f.Id).ToHashSet();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"讀取失敗： {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task SaveToIndexedDb(SocialPost post)
    {
        bool isAdding = !_collectedIds.Contains(post.Id);
        if (isAdding)
        {
            _collectedIds.Add(post.Id);
        }
        else
        {
            _collectedIds.Remove(post.Id);
        }
        StateHasChanged();

        try
        {
            if (isAdding)
            {
                await PostDbService.UpsertFavoriteAsync(post);
            }
            else
            {
                await PostDbService.RemoveFavoriteAsync(post.Id);
            }

            Snackbar.Add(isAdding ? "已加入收藏清單！": "已取消收藏",
                isAdding ? Severity.Success : Severity.Info);
        }
        catch (Exception ex)
        {
            if (isAdding)
            {
                _collectedIds.Remove(post.Id);
            }
            else
            {
                _collectedIds.Add(post.Id);
            }

            Snackbar.Add($"資料庫同步失敗: {ex.Message}",
                Severity.Error);
            StateHasChanged();
        }
    }

    private bool IsCollected(string id)
    {
        return _collectedIds.Contains(id);
    }
}