@page "/settings"

@using AutoCatch.Models
@using MudBlazor

@inject ISnackbar Snackbar
@inject SettingDbService SettingDbService

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8">
        @* <MudText Typo="Typo.h5"
                 Align="Align.Center"
                 Class="mb-6 mud-text-primary"
                 Style="font-weight: 800;">
            爬蟲設定
        </MudText> *@

    <MudPaper Class="mud-glass pa-6 mb-6">
        <div class="d-flex align-center justify-space-between">
            <MudText Typo="Typo.subtitle1"
                     Style="font-weight: bold;">
                PTT 追蹤看板
            </MudText>
            <MudSwitch @bind-Value="_pttSettings.Enabled"
                       Color="Color.Primary" />
        </div>

        @if (_pttSettings.Enabled)
        {
            <MudPaper Elevation="0"
                      Class="pa-4 mb-6"
                      Style="background: rgba(230, 213, 184, 0.1);
                             border: 1px dashed #E6D5B8;">
                <MudNumericField
                    @bind-Value="_pttSettings.RefreshIntervalMinutes" 
                    Label="抓取間隔 (分鐘)" 
                    Variant="Variant.Text" 
                    Min="5" 
                    HelperText="所有看板將共用此掃描頻率"
                    Margin="Margin.Dense" />
            </MudPaper>

            <div class="mt-4">
                @* 看板新增區 (限制最多 3 個) *@
                <div class="d-flex align-start mb-4">
                    <MudTextField @bind-Value="_currentBoard"
                                  Label="新增看板 (上限 3 個)" 
                                  Variant="Variant.Outlined" 
                                  Margin="Margin.Dense"
                                  Disabled="@(_pttSettings.BoardConfigs.Count >= 3)"
                                  Placeholder="例如: Lifeismoney"
                                  OnKeyDown="@HandleKeyDown" />
                    <MudIconButton Icon="@Icons.Material.Filled.Add"
                                   OnClick="AddBoard"
                                   Disabled="@(_pttSettings.BoardConfigs.Count >= 3 || string.IsNullOrEmpty(_currentBoard))"
                                   Color="Color.Primary" 
                                   Class="ml-2 mt-1" />
                </div>

                @* 個別看板設定卡片 *@
                <MudStack Spacing="3">
                    @foreach (var config in _pttSettings.BoardConfigs)
                    {
                        <MudPaper Class="pa-4 mud-glass"
                                  Style="background: rgba(0,0,0,0.03);
                                         border-radius: 12px;">
                            <div class="d-flex justify-space-between align-center mb-2">
                                <MudText Typo="Typo.subtitle1"
                                         Style="font-weight: 900; color: var(--mud-palette-primary);">
                                    @config.Name
                                </MudText>
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                               Size="Size.Small" 
                                               Color="Color.Error" 
                                               OnClick="@(() => _pttSettings.BoardConfigs.Remove(config))" />
                            </div>

                            <MudGrid Spacing="2">
                                <MudItem xs="4">
                                    <MudNumericField
                                        @bind-Value="config.NumPost"
                                        Label="文章數" 
                                        Variant="Variant.Text"
                                        Min="1"
                                        Max="100"
                                        Margin="Margin.Dense"
                                        HideSpinButtons="true" />
                                </MudItem>
                                <MudItem xs="4">
                                    <MudNumericField
                                        @bind-Value="config.MinNrec"
                                        Label="推文數" 
                                        Variant="Variant.Text"
                                        Min="0"
                                        Margin="Margin.Dense"
                                        HideSpinButtons="true" />
                                </MudItem>
                                <MudItem xs="4">
                                    <MudCheckBox
                                        @bind-Value="config.HideReplies" 
                                        Label="過濾 Re:" 
                                        Color="Color.Primary" 
                                        Dense="true"
                                        Size="Size.Small" />
                                    <MudCheckBox
                                        @bind-Value="config.HideGiveMoney" 
                                        Label="過濾 發錢" 
                                        Color="Color.Primary" 
                                        Dense="true"
                                        Size="Size.Small" />
                                </MudItem>
                            </MudGrid>
                        </MudPaper>
                    }
                </MudStack>
            </div>
        }

        <MudButton Variant="Variant.Filled" 
                   Color="Color.Primary" 
                   FullWidth="true" 
                   Class="mt-8 py-3" 
                   OnClick="SavePttSettingsAsync">
            <MudText>
                儲存設定
            </MudText>
        </MudButton>
    </MudPaper>

</MudContainer>

@code {
    private PttSettings _pttSettings = new();
    private string _currentBoard = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        // 取得設定
        _pttSettings = await SettingDbService.GetPttSettingsAsync();
    }

    private void AddBoard()
    {
        if (_pttSettings.BoardConfigs.Count >= 3)
        {
            Snackbar.Add("雷達頻道已滿，最多只能追蹤 3 個看板喔！",
                Severity.Warning);
            return;
        }

        if (!string.IsNullOrWhiteSpace(_currentBoard))
        {
            var boardName = _currentBoard.Trim();
            if (_pttSettings.BoardConfigs.Any(
                x => x.Name.Equals(
                    boardName, StringComparison.OrdinalIgnoreCase)))
            {
                Snackbar.Add("這個看板已經在清單中囉。", Severity.Info);
                return;
            }

            _pttSettings.BoardConfigs.Add(
                new PttBoardConfig { Name = boardName });
            _currentBoard = "";
            StateHasChanged();
        }
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") AddBoard();
    }

    private async Task SavePttSettingsAsync()
    {
        try
        {
            await SettingDbService.SavePttSettingsAsync(_pttSettings);
            Snackbar.Add("設定已儲存", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"儲存失敗: {ex.Message}",
                Severity.Error);
        }
    }
}