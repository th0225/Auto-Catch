@page "/settings"

@using AutoCatch.Models
@using MudBlazor

@inject ISnackbar Snackbar
@inject SettingDbService SettingDbService

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8">
        @* <MudText Typo="Typo.h5"
                 Align="Align.Center"
                 Class="mb-6 mud-text-primary"
                 Style="font-weight: 800;">
            爬蟲設定
        </MudText> *@

    <MudPaper Class="mud-glass pa-6 mb-6">
        <div class="d-flex align-center justify-space-between">
            <MudText Typo="Typo.subtitle1"
                     Style="font-weight: bold;">
                PTT 追蹤看板
            </MudText>
            <MudSwitch @bind-Value="_pttSettings.Enabled"
                       Color="Color.Primary" />
        </div>

        @if (_pttSettings.Enabled)
        {
            <div class="mt-4">
                @* 看板新增區 (限制最多 3 個啟用的看板) *@
                <div class="d-flex align-start mb-6">
                    <MudTextField @bind-Value="_currentBoard"
                                  Label="新增看板 (上限 3 個)" 
                                  Variant="Variant.Outlined" 
                                  Margin="Margin.Dense"
                                  Disabled="@(_pttSettings.BoardConfigs.Count(c => c.Enabled) >= 3)"
                                  Placeholder="例如: Lifeismoney"
                                  OnKeyDown="@HandleKeyDown" />
                    <MudIconButton Icon="@Icons.Material.Filled.Add"
                                   OnClick="AddBoard"
                                   Disabled="@(_pttSettings.BoardConfigs.Count(c => c.Enabled) >= 3 || string.IsNullOrEmpty(_currentBoard))"
                                   Color="Color.Primary" 
                                   Class="ml-2 mt-1" />
                </div>

                @* 個別看板設定卡片 *@
                <MudStack Spacing="3">
                    @foreach (var config in _pttSettings.BoardConfigs)
                    {
                        <MudPaper Class="pa-4 mud-glass"
                                  Style="@GetBoardStyle(config)">
                            <div class="d-flex justify-space-between align-center mb-2">
                                <MudText Typo="Typo.subtitle1"
                                         Style="font-weight: 900; color: var(--mud-palette-primary);">
                                    @config.Name
                                </MudText>
                                <MudSwitch @bind-Value="config.Enabled"
                                           Color="Color.Primary"
                                           Size="Size.Small"
                                           Label="@(config.Enabled ? "啟用" : "停用")" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                               Size="Size.Small" 
                                               Color="Color.Error" 
                                               OnClick="@(() => RemoveBoard(config.Name))" />
                            </div>

                            <MudGrid Spacing="2">
                                <MudItem xs="4">
                                    <MudNumericField
                                        @bind-Value="config.NumPost"
                                        Label="文章數" 
                                        Variant="Variant.Text"
                                        Min="1"
                                        Max="100"
                                        Margin="Margin.Dense"
                                        HideSpinButtons="true"
                                        Disabled="!config.Enabled" />
                                </MudItem>
                                <MudItem xs="4">
                                    <MudNumericField
                                        @bind-Value="config.MinNrec"
                                        Label="推文數" 
                                        Variant="Variant.Text"
                                        Min="0"
                                        Margin="Margin.Dense"
                                        HideSpinButtons="true"
                                        Disabled="!config.Enabled" />
                                </MudItem>
                                <MudItem xs="4">
                                    <MudCheckBox
                                        @bind-Value="config.HideReplies" 
                                        Label="過濾 Re:" 
                                        Color="Color.Primary" 
                                        Dense="true"
                                        Size="Size.Small"
                                        Disabled="!config.Enabled" />
                                    <MudCheckBox
                                        @bind-Value="config.HideGiveMoney" 
                                        Label="過濾 發錢" 
                                        Color="Color.Primary" 
                                        Dense="true"
                                        Size="Size.Small"
                                        Disabled="!config.Enabled" />
                                </MudItem>
                            </MudGrid>
                        </MudPaper>
                    }
                </MudStack>
            </div>
        }

        <MudButton Variant="Variant.Filled" 
                   Color="Color.Primary" 
                   FullWidth="true" 
                   Class="mt-8 py-3" 
                   OnClick="SavePttSettingsAsync">
            <MudText>
                儲存設定
            </MudText>
        </MudButton>
    </MudPaper>

</MudContainer>

<style>
    .mud-glass {
        transition: all 0.3s ease;
    }
    .mud-glass:hover {
        transform: translateY(-2px);
    }
</style>

@code {
    private PttSettings _pttSettings = new();
    private string _currentBoard = string.Empty;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // 取得設定
            _pttSettings = await SettingDbService.GetPttSettingsAsync();
            StateHasChanged();
        }
    }

    private void AddBoard()
    {
        if (_pttSettings.BoardConfigs.Count(c => c.Enabled) >= 3)
        {
            Snackbar.Add("雷達頻道已滿，最多只能追蹤 3 個看板喔！",
                Severity.Warning);
            return;
        }

        if (!string.IsNullOrWhiteSpace(_currentBoard))
        {
            var boardName = _currentBoard.Trim();
            if (!System.Text.RegularExpressions.Regex.IsMatch(boardName, @"^[a-zA-Z0-9_-]+$"))
            {
                Snackbar.Add("看板名稱只能使用英文、數字、底線和連字號。", Severity.Warning);
                return;
            }

            if (_pttSettings.BoardConfigs.Any(
                x => x.Name.Equals(
                    boardName, StringComparison.OrdinalIgnoreCase)))
            {
                Snackbar.Add("這個看板已經在清單中囉。", Severity.Info);
                return;
            }

            _pttSettings.BoardConfigs.Add(
                new PttBoardConfig { Name = boardName });
            _currentBoard = "";
            StateHasChanged();
        }
    }

    private void RemoveBoard(string boardName)
    {
        var config = _pttSettings.BoardConfigs
            .FirstOrDefault(x => x.Name == boardName);
        if (config != null)
        {
            _pttSettings.BoardConfigs.Remove(config);
            StateHasChanged();
        }
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") AddBoard();
    }

    private string GetBoardStyle(PttBoardConfig config)
    {
        return config.Enabled
            ? "background: rgba(0,0,0,0.03); border-radius: 12px;"
            : "background: rgba(0,0,0,0.03); border-radius: 12px; opacity: 0.5;";
    }

    private async Task SavePttSettingsAsync()
    {
        try
        {
            await SettingDbService.SavePttSettingsAsync(_pttSettings);
            Snackbar.Add("設定已儲存", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"儲存失敗: {ex.Message}",
                Severity.Error);
        }
    }
}