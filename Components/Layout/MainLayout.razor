@inherits LayoutComponentBase

@inject IJSRuntime JS

<MudThemeProvider Theme="CustomTheme" @bind-IsDarkMode="@_isDarkMode" />
<MudPopoverProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0" Class="main-appbar">
        <MudText Typo="Typo.h6" Class="ml-3 appbar-title">
            Auto Catch
        </MudText>
        <MudSpacer />
        <MudIconButton
            Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode
                                : Icons.Material.Filled.DarkMode)" 
            Color="Color.Inherit" 
            OnClick="@DarkModeToggle"" />
        <MudIconButton Icon="@Icons.Custom.Brands.GitHub"
            Color="Color.Inherit" 
            Href="https://github.com/th0225"
            Target="_blank" />
    </MudAppBar>

    <MudMainContent Class="pb-16">
        @Body
    </MudMainContent>

    <MudAppBar Bottom="true"
               Fixed="true"
               Elevation="4"
               Class="bottom-appbar">
        <div class="d-flex justify-space-around w-100">
            <MudIconButton Icon="@Icons.Material.Filled.Radar"
                           Color="Color.Inherit"
                           href="/" />
            <MudIconButton Icon="@Icons.Material.Filled.Favorite"
                           Color="Color.Inherit"
                           href="/favorites" />
            <MudIconButton Icon="@Icons.Material.Filled.Settings" 
                           Color="Color.Inherit"
                           Href="/settings" />
        </div>
    </MudAppBar>
</MudLayout>

<style>
    .main-appbar.mud-appbar {
        background-color: var(--mud-palette-appbar-background) !important;
        backdrop-filter: blur(20px) saturate(180%) !important;
        -webkit-backdrop-filter: blur(20px) saturate(180%) !important;
        border-bottom: 0.5px solid rgba(166, 137, 102, 0.15) !important;
        color: var(--mud-palette-text-primary) !important; 
    }

    .bottom-appbar.mud-appbar {
        background-color: var(--mud-palette-appbar-background) !important;
        backdrop-filter: blur(20px) saturate(180%) !important;
        -webkit-backdrop-filter: blur(20px) saturate(180%) !important;
        border-top: 0.5px solid rgba(166, 137, 102, 0.15) !important;
        color: var(--mud-palette-text-primary) !important; 
    }

    .mud-main-content {
        padding-bottom: 80px !important;
    }

    .appbar-title {
        color: var(--mud-palette-text-primary) !important;
        font-weight: 800 !important;
    }

    .content-title {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        line-height: 1.4;
    }
</style>

@code {
    bool _isDarkMode = false;

    private string MainContentStyle => _isDarkMode
        ? "background-color: #1A1A19;" 
        : "background-color: #FAF9F6;";

    private async Task DarkModeToggle() 
    {
        _isDarkMode = !_isDarkMode;

        await JS.InvokeVoidAsync("localStorage.setItem",
            "darkMode", _isDarkMode);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var result = await JS.InvokeAsync<string>(
                "localStorage.getItem",
                "darkMode");
            _isDarkMode = (result == "true");
            StateHasChanged();
        }
    }

    private MudTheme CustomTheme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#A68966",
            Secondary = "#F0E5D1",
            Background = "#FFFDF9",
            AppbarBackground = "#FFFDF9",
            Surface = "#FFFFFF",
            TextPrimary = "#5F4B32",
            TextSecondary = "#8D7B68",
            ActionDefault = "#E6D5B8",
            DrawerBackground = "#FFFDF9",
            Divider = "#F0E5D1"
        },
        PaletteDark = new PaletteDark()
        {
            Primary = "#E6D5B8",
            Background = "#1A1A19",
            Surface = "#262624",
            AppbarBackground = "rgba(26, 26, 25, 0.6)",
            TextPrimary = "#E3DED0",
            TextSecondary = "#8D7B68",
            ActionDefault = "#E6D5B8",
            Divider = "#333330"
        },
        LayoutProperties = new LayoutProperties()
        {
            DefaultBorderRadius = "20px",
            DrawerWidthLeft = "260px"
        },
        Typography = new Typography()
        {
            Default = new DefaultTypography()
            {
                FontFamily = new[] {
                    "Noto Sans TC", "微軟正黑體", "sans-serif"
                }
            }
        }
    };
}